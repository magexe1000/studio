{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for(const f of ['package-lock.json','yarn.lock'])try{fs.unlinkSync(f)}catch{};const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm build:web && pnpm build:android:web",
    "build:web": "pnpm --filter @workspace/studio-web build",
    "build:android:web": "pnpm --filter @workspace/studio-android build",
    "build:android": "pnpm --filter @workspace/studio-android android:build",
    "typecheck:libs": "tsc --build",
    "typecheck:web": "pnpm run typecheck:libs && pnpm --filter @workspace/studio-web typecheck",
    "typecheck:android": "pnpm run typecheck:libs && pnpm --filter @workspace/studio-android typecheck",
    "test:web": "pnpm --filter @workspace/studio-web test",
    "test:android": "pnpm --filter @workspace/studio-android test",
    "version:web": "node scripts/version-manager.mjs web",
    "version:android": "node scripts/version-manager.mjs android",
    "lint:imports": "node scripts/enforce-import-boundaries.mjs",
    "check:versions": "node scripts/verify-versions-consistency.mjs"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@octokit/rest": "^22.0.1",
    "adm-zip": "^0.5.16"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@8.3.0": "8.4.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "lodash@4.17.23": "4.18.0",
      "brace-expansion@2.0.2": "2.0.3",
      "esbuild@0.18.20": "0.25.0",
      "yaml@2.8.2": "2.8.3",
      "@xmldom/xmldom": "0.8.13",
      "dompurify": "3.4.0",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.1.7",
      "fast-xml-parser": "5.7.0",
      "postcss": "8.5.10",
      "tar": "6.2.1"
    },
    "packageExtensions": {
      "@capacitor/cli@6.2.1": {
        "dependencies": {
          "tar": "^6.2.1"
        }
      }
    }
  }
}
