# ── Line endings ──────────────────────────────────────────────────────────────
# Normalize all text files to LF in the repo, check out as-is on all platforms.
* text=auto eol=lf

# Force LF for files that must never have CRLF (shell scripts, configs, JSON).
*.sh    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary files — do not attempt line-ending conversion or text diffing.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.rar   binary
*.ogg   binary
*.mp3   binary
*.wav   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

