{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": ["node", "vite/client"],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json", "firebase.config.json"],
  "references": [
    { "path": "../../lib/db" },
    { "path": "../../lib/api-client-react" }
  ]
}
