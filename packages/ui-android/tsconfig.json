{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "baseUrl": ".",
    "types": [
      "node",
      "vite/client"
    ],
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "src/**/*.json",
    "firebase.config.json"
  ],
  "references": [
    {
      "path": "../studio-core"
    },
    {
      "path": "../ui-shared"
    }
  ]
}
